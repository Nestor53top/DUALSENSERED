<Application x:Class="DualSenseRed.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="PixelFont">pack://application:,,,/assets/#Pixel Impacted</FontFamily>

        <SolidColorBrush x:Key="BgDark" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="BgPanel" Color="#111111"/>
        <SolidColorBrush x:Key="BgCard" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="RedPrimary" Color="#E5143C"/>
        <SolidColorBrush x:Key="RedDark" Color="#8B0A22"/>
        <SolidColorBrush x:Key="RedGlow" Color="#FF1A3D"/>
        <SolidColorBrush x:Key="TextWhite" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextGray" Color="#777777"/>
        <SolidColorBrush x:Key="BorderDark" Color="#2A2A2A"/>
    </Application.Resources>
</Application>
