<Window x:Class="DualSenseRed.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DualSense Red" Height="320" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>
        <Grid.Effect>
            <DropShadowEffect BlurRadius="80" ShadowDepth="0" Color="#E5143C" Opacity="0.6"/>
        </Grid.Effect>

        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.6" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                <GradientStop Color="#30E5143C" Offset="0"/>
                <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Hello" Foreground="White" FontSize="48" FontWeight="Light"
                       HorizontalAlignment="Center" FontFamily="{StaticResource PixelFont}"/>

            <Button x:Name="BtnTap" Content="TAP" Margin="0,24,0,0"
                    Width="160" Height="52"
                    Background="#E5143C" Foreground="White"
                    FontSize="18" FontWeight="Bold"
                    FontFamily="{StaticResource PixelFont}"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnTap_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#E5143C" Opacity="0.8"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</Window>
